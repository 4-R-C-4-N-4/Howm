{
  "name": "social.feed",
  "version": "0.1.0",
  "description": "Distributed feed capability",
  "binary": "./feed",
  "port": 7001,
  "api": {
    "base_path": "/cap/feed",
    "endpoints": [
      { "name": "get_feed", "method": "GET", "path": "/feed" },
      { "name": "create_post", "method": "POST", "path": "/post" },
      { "name": "health", "method": "GET", "path": "/health" }
    ]
  },
  "permissions": {
    "visibility": "friends"
  },
  "ui": {
    "label": "Feed",
    "icon": "message-circle",
    "entry": "/ui/",
    "style": "iframe"
  }
}
